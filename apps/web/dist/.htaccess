RewriteEngine On

# Keep the production app on the apex domain so deep links use the same origin
# as stored auth tokens.
RewriteCond %{HTTP_HOST} ^www\.irlobby\.com$ [NC]
RewriteRule ^ https://irlobby.com%{REQUEST_URI} [R=301,L,NE]

# Preserve direct requests for real files/directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Redirect legacy .html URLs to clean route paths
RewriteRule ^index\.html$ / [R=301,L]
RewriteRule ^features\.html$ /features [R=301,L]
RewriteRule ^how-it-works\.html$ /how-it-works [R=301,L]
RewriteRule ^download\.html$ /download [R=301,L]
RewriteRule ^support\.html$ /support [R=301,L]
RewriteRule ^privacy\.html$ /privacy [R=301,L]
RewriteRule ^privacy-policy\.html$ /privacy [R=301,L]
RewriteRule ^terms\.html$ /terms [R=301,L]
RewriteRule ^terms-of-service\.html$ /terms [R=301,L]

# Client-side routing fallback for React Router
RewriteRule ^ index.html [L]
