# Django configuration
# keep SECRET_KEY secret in production
SECRET_KEY=your_django_secret_key_here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# Database configuration
# default uses local sqlite; override with a PostgreSQL URL for production
DATABASE_URL=sqlite:///db.sqlite3
# e.g. postgresql://user:password@db:5432/irlobby

# CORS / CSRF
# comma-separated list of allowed origins for browser requests
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend base URL (used in password reset links, etc.)
FRONTEND_BASE_URL=http://localhost:5173/

# OAuth / social auth
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Email / SMTP (optional for development; console backend is default)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password
# DEFAULT_FROM_EMAIL=no-reply@example.com

# Expo push notifications (mobile)
EXPO_PUSH_API_URL=https://exp.host/--/api/v2/push/send
EXPO_PUSH_ACCESS_TOKEN=

# Any other custom settings can be added below
