{
  "name": "irlobby",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "bundle:ios": "expo export --platform ios",
    "build:ios": "eas build -p ios --profile production",
    "submit:ios": "eas submit -p ios --profile production",
    "build:android": "eas build -p android --profile production",
    "submit:android": "eas submit -p android --profile production",
    "capture:store-screenshots": "EXPO_PUBLIC_SCREENSHOT_MODE=1 expo start --web --port 19008",
    "capture:screenshots:ios": "node scripts/capture-store-screenshots.mjs ios",
    "capture:screenshots:android": "node scripts/capture-store-screenshots.mjs android",
    "presubmit": "bash scripts/pre-submit-check.sh",
    "test": "jest"
  },
  "dependencies": {
    "@expo-google-fonts/outfit": "^0.4.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.4.8",
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/native-stack": "^7.3.27",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/query-async-storage-persister": "^5.99.2",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-query-persist-client": "^5.99.2",
    "axios": "^1.12.2",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.9",
    "expo-contacts": "^15.0.11",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "lottie-react-native": "~7.3.1",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-modal": "^14.0.0-rc.1",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.6.1",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^54.0.10",
    "baseline-browser-mapping": "^2.9.19",
    "expo-module-scripts": "^5.0.8",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "playwright": "^1.59.1",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-webview",
        "react-native-worklets"
      ]
    }
  },
  "private": true
}
